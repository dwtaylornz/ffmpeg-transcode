{
    "global_settings": {
        "min_threads": 2,
        "max_threads": 8,
        "gpu_target_pct": 95,
        "gpu_ramp_wait": 30,
        "gpu_check_interval": 30,
        "vcn_sample_interval": 1,
        "ffmpeg_input_params": "-err_detect ignore_err -ignore_unknown -vaapi_device /dev/dri/renderD128",
        "scan_at_start": 1,
        "restart_queue": 720,
        "ffmpeg_timeout": 6000,
        "ffmpeg_logging": "error",
        "ffmpeg_min_diff": 5,
        "ffmpeg_max_diff": 95,
        "move_file": 1,
        "days_to_seconds": 86400,
        "minutes_to_seconds": 60,
        "duration_tolerance": 30,
        "ffmpeg_nice_priority": 15,
        "skip_file": "./skip.csv",
        "sleep_before_move": 5,
        "sleep_after_move": 2,
        "output_path": "/dev/shm/ffmpeg-transcode",
        "colors": {
            "red": "\u001b[1;91m",
            "orange": "\u001b[0;33m",
            "yellow": "\u001b[1;93m",
            "green": "\u001b[1;92m",
            "reset": "\u001b[0m"
        }
    },
    "configurations": [
        {
            "name": "movies",
            "media_path": "/videos/movies",
            "min_video_size": 0,
            "min_video_age": 10,
            "ffmpeg_output_params": "-vf 'format=nv12,hwupload' -c:v av1_vaapi -c:a copy -b:v 5M -maxrate 10M -bufsize 10M -max_muxing_queue_size 9999",
            "video_codec_skip_list": "av1"
        },
        {
            "name": "series",
            "media_path": "/videos/series",
            "min_video_size": 0,
            "min_video_age": 10,
            "ffmpeg_output_params": "-vf 'format=nv12,hwupload' -c:v av1_vaapi -c:a copy -b:v 5M -maxrate 10M -bufsize 10M -max_muxing_queue_size 9999",
            "video_codec_skip_list": "av1"
        }
    ]
}